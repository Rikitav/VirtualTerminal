<UserControl x:Class="VirtualTerminal.PromptBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:VirtualTerminal"
             mc:Ignorable="d" x:Name="this"
             d:DesignHeight="450" d:DesignWidth="800">
    
    <Border Background="#1E1E1E">
        <Grid ColumnDefinitions="Auto,*,30">
            <TextBlock
                x:Name="PART_Prompt"
                Grid.Column="0"
                Margin="5,0,5,0"
                DockPanel.Dock="Left"
                Text="{Binding Prompt, ElementName=this}"
                TextAlignment="Right"
                Foreground="{Binding Foreground, ElementName=this}"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Center"/>

            <TextBox
                x:Name="PART_Input"
                Grid.Column="1"
                Margin="0,0,5,0"
                VerticalAlignment="Center"
                HorizontalAlignment="Stretch"
                BorderThickness="0"
                Background="Transparent"
                
                IsEnabled="{Binding IsInputEnabled, ElementName=this}"
                Text="{Binding InputText, ElementName=this, UpdateSourceTrigger=PropertyChanged}"
                TextAlignment="Left"
                TextWrapping="NoWrap"
                CaretBrush="{Binding Foreground, ElementName=this}"
                Foreground="{Binding Foreground, ElementName=this}"
                
                PreviewKeyDown="PART_Input_PreviewKeyDown"
                GotFocus="PART_Input_GotFocus" />

            <Button x:Name="PART_Enter"
                Grid.Column="2"
                Click="PART_Enter_Click"/>
        </Grid>
    </Border>
</UserControl>
